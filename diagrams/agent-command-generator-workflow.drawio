        <mxCell id="flow_quality_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#d5e8d4;" edge="1" source="gw_quality_ok" target="task_write_output" parent="lane_orchestrator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_write_register" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_write_output" target="task_register" parent="lane_orchestrator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_register_end" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_register" target="evt_end" parent="lane_orchestrator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- LANE 3: Prompt Architect                                     -->
        <!-- ============================================================ -->
        <mxCell id="lane_prompt_architect" value="Prompt Architect" style="shape=mxgraph.bpmn.lane;startSize=40;fillColor=#d5e8d4;strokeColor=#82b366;horizontal=1;swimlaneHead=0;fontStyle=1;fontSize=11;" vertex="1" parent="pool1">
          <mxGeometry y="1030" width="5400" height="1000" as="geometry" />
        </mxCell>

        <!-- PHASE 3 LABEL -->
        <mxCell id="phase3_label" value="PHASE 3: Prompt Construction" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#82b366;" vertex="1" parent="lane_prompt_architect">
          <mxGeometry x="1000" y="40" width="260" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Design Role Persona -->
        <object label="Design Role&#xa;Persona" agent="agent_generator_prompt_architect" phase="3" phase_name="Prompt Construction" mandatory="true" status_from="deep_researched" status_to="persona_designed" rule="Create character name, background, experience narrative based on deep research findings - the embodiment section" id="task_design_persona">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=user;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
            <mxGeometry x="1000" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Define Expertise Sections -->
        <object label="Define Expertise&#xa;Sections" agent="agent_generator_prompt_architect" phase="3" phase_name="Prompt Construction" mandatory="true" status_from="persona_designed" status_to="expertise_defined" rule="Technical skills, available tools, MCP server integrations" id="task_define_expertise">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=user;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
            <mxGeometry x="1240" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Write Workflow Instructions -->
        <object label="Write Workflow&#xa;Instructions" agent="agent_generator_prompt_architect" phase="3" phase_name="Prompt Construction" mandatory="true" status_from="expertise_defined" status_to="workflow_written" rule="Primary workflow, decision-making rules, output format guidelines" id="task_write_workflow">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=user;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
            <mxGeometry x="1480" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Compose Description Field -->
        <object label="Compose Description&#xa;Field" agent="agent_generator_prompt_architect" phase="3" phase_name="Prompt Construction" mandatory="true" status_from="workflow_written" status_to="description_composed" rule="Write the 1-2 sentence description for frontmatter - must be concise but informative" id="task_compose_description">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=user;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
            <mxGeometry x="1720" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Phase 3 Flows -->
        <mxCell id="flow_persona_expertise" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_design_persona" target="task_define_expertise" parent="lane_prompt_architect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_expertise_workflow" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_define_expertise" target="task_write_workflow" parent="lane_prompt_architect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_workflow_description" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_write_workflow" target="task_compose_description" parent="lane_prompt_architect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- PHASE 3C: Command Construction (Prompt Architect lane)       -->
        <!-- ============================================================ -->

        <!-- PHASE 3C LABEL -->
        <mxCell id="phase3c_label" value="PHASE 3C: Command Construction" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#d79b00;" vertex="1" parent="lane_prompt_architect">
          <mxGeometry x="1000" y="260" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Design Command Orchestrator Role -->
        <object label="Design Command&#xa;Orchestrator Role" agent="agent_generator_prompt_architect" phase="3C" phase_name="Command Construction" mandatory="true" status_from="deep_researched" status_to="command_role_designed" rule="Define the orchestrator role and purpose. Commands use direct instruction style (no persona/embodiment). Start with 'You are now the **Orchestrator** for the X Workflow.' pattern." id="task_design_command_role">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=user;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
            <mxGeometry x="1000" y="300" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Define Command Rules & Constraints -->
        <object label="Define Command&#xa;Rules &amp; Constraints" agent="agent_generator_prompt_architect" phase="3C" phase_name="Command Construction" mandatory="true" status_from="command_role_designed" status_to="command_rules_defined" rule="Write mandatory rules, startup sequence, tool usage patterns, and $ARGUMENTS handling. Commands reference BPMN diagrams, MCP tools, and agent delegation patterns." id="task_define_command_rules">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=user;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
            <mxGeometry x="1240" y="300" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Write Command Navigation Logic -->
        <object label="Write Command&#xa;Navigation Logic" agent="agent_generator_prompt_architect" phase="3C" phase_name="Command Construction" mandatory="true" status_from="command_rules_defined" status_to="command_navigation_written" rule="Define phase-by-phase execution, gateway handling, correction loops, and inter-agent communication patterns. Include how to handle $ARGUMENTS from the user's slash command invocation." id="task_write_command_navigation">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=user;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
            <mxGeometry x="1480" y="300" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Compose Command Skill Entry -->
        <object label="Compose Command&#xa;Skill Entry" agent="agent_generator_prompt_architect" phase="3C" phase_name="Command Construction" mandatory="true" status_from="command_navigation_written" status_to="description_composed" rule="Write the skill entry for the commands system prompt. This includes the trigger description that tells Claude when to invoke this command. Note: commands have NO frontmatter - they start directly with content." id="task_compose_command_entry">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=user;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
            <mxGeometry x="1720" y="300" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Phase 3C Flows -->
        <mxCell id="flow_cmd_role_rules" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_design_command_role" target="task_define_command_rules" parent="lane_prompt_architect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_cmd_rules_nav" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_define_command_rules" target="task_write_command_navigation" parent="lane_prompt_architect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_cmd_nav_entry" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_write_command_navigation" target="task_compose_command_entry" parent="lane_prompt_architect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Annotation: Command tasks info -->
        <mxCell id="note_command_info" value="Commands have NO frontmatter.&#xa;Start with orchestrator prompt.&#xa;Use $ARGUMENTS for user input." style="shape=note2;size=15;fillColor=#ffffcc;strokeColor=#d6b656;fontSize=10;whiteSpace=wrap;" vertex="1" parent="lane_prompt_architect">
          <mxGeometry x="1000" y="400" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- LANE 4: Token Validator                                      -->
        <!-- ============================================================ -->
        <mxCell id="lane_token_validator" value="Token Validator" style="shape=mxgraph.bpmn.lane;startSize=40;fillColor=#fff2cc;strokeColor=#d6b656;horizontal=1;swimlaneHead=0;fontStyle=1;fontSize=11;" vertex="1" parent="pool1">
          <mxGeometry y="2030" width="5400" height="640" as="geometry" />
        </mxCell>

        <!-- PHASE 4 LABEL -->
        <mxCell id="phase4_label" value="PHASE 4: Token Validation &amp; Assembly" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#d6b656;" vertex="1" parent="lane_token_validator">
          <mxGeometry x="2000" y="40" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Count Tokens -->
        <object label="Count Tokens" agent="agent_generator_token_validator" phase="4" phase_name="Token Validation &amp; Assembly" mandatory="true" status_from="description_composed" status_to="tokens_counted" rule="Measure total token count of the generated content using tokenizer" id="task_count_tokens">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=service;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_token_validator">
            <mxGeometry x="2000" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Gateway: Under 15k tokens? -->
        <mxCell id="gw_token_limit" value="Under 15k&#xa;Tokens?" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;gwType=exclusive;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="lane_token_validator">
          <mxGeometry x="2260" y="85" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Task: Trim & Optimize -->
        <object label="Trim &amp;&#xa;Optimize" agent="agent_generator_token_validator" phase="4" phase_name="Token Validation &amp; Assembly" mandatory="true" status_from="tokens_exceeded" status_to="optimized" rule="Reduce verbosity, remove redundancy, compress examples while preserving quality" id="task_trim_optimize">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=script;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_token_validator">
            <mxGeometry x="2160" y="250" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Assemble Final File -->
        <object label="Assemble Final&#xa;File" agent="agent_generator_token_validator" phase="4" phase_name="Token Validation &amp; Assembly" mandatory="true" status_from="tokens_counted" status_to="assembled" rule="Combine frontmatter (name, description, model) + markdown body into final .md file" id="task_assemble_file">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_token_validator">
            <mxGeometry x="2480" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Annotation: Token limit -->
        <mxCell id="note_token_limit" value="description field must&#xa;stay under 15,000 tokens" style="shape=note2;size=15;fillColor=#ffffcc;strokeColor=#d6b656;fontSize=10;whiteSpace=wrap;" vertex="1" parent="lane_token_validator">
          <mxGeometry x="2350" y="200" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Phase 4 Flows -->
        <mxCell id="flow_count_gw_token" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_count_tokens" target="gw_token_limit" parent="lane_token_validator">
          <mxGeometry relative="1" as="geometry" />
