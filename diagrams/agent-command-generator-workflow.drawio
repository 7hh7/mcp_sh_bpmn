          </mxCell>
        </object>

        <!-- END EVENT -->
        <mxCell id="evt_end" value="" style="shape=mxgraph.bpmn.event;perimeter=ellipsePerimeter;symbol=terminate;isLooping=0;isInterrupting=0;isConditional=0;outline=end;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=3;" vertex="1" parent="lane_orchestrator">
          <mxGeometry x="4040" y="90" width="40" height="40" as="geometry" />
