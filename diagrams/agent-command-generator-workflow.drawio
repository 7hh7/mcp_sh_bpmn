          <mxGeometry x="340" y="200" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Annotation: Skill path -->
        <mxCell id="note_skill_path" value="Command path:&#xa;check ~/.claude/commands/" style="shape=note2;size=15;fillColor=#ffffcc;strokeColor=#d6b656;fontSize=10;whiteSpace=wrap;" vertex="1" parent="lane_orchestrator">
          <mxGeometry x="340" y="280" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- PHASE 5 LABEL -->
        <mxCell id="phase5_label" value="PHASE 5: Quality Check &amp; Output" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#6c8ebf;" vertex="1" parent="lane_orchestrator">
          <mxGeometry x="2900" y="40" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Validate File Structure -->
        <object label="Validate File&#xa;Structure" agent="agent_generator_orchestrator" phase="5" phase_name="Quality Check &amp; Output" mandatory="true" status_from="assembled" status_to="validating" rule="Check frontmatter fields present, markdown valid, no broken references" id="task_validate_structure">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=service;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestrator">
            <mxGeometry x="2900" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Verify No Duplicates -->
        <object label="Verify No&#xa;Duplicates" agent="agent_generator_orchestrator" phase="5" phase_name="Quality Check &amp; Output" mandatory="true" status_from="validating" status_to="verified" rule="Confirm no existing agent/skill with same name or overlapping description" id="task_verify_duplicates">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=service;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestrator">
            <mxGeometry x="3140" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Gateway: Quality OK? -->
        <mxCell id="gw_quality_ok" value="Quality&#xa;OK?" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;gwType=exclusive;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="lane_orchestrator">
          <mxGeometry x="3380" y="85" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Task: Write Output File -->
        <object label="Write Output&#xa;File" agent="agent_generator_orchestrator" phase="5" phase_name="Quality Check &amp; Output" mandatory="true" status_from="verified" status_to="written" rule="Write to ~/.claude/agents/ for agents or ~/.claude/commands/ for skills" id="task_write_output">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=send;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestrator">
            <mxGeometry x="3540" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Register Agent/Skill -->
        <object label="Register&#xa;Agent/Skill" agent="agent_generator_orchestrator" phase="5" phase_name="Quality Check &amp; Output" mandatory="false" status_from="written" status_to="registered" rule="If applicable, run claude mcp add or register the new agent/skill" id="task_register">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=script;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestrator">
