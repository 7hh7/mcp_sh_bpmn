<mxfile host="app.diagrams.net" compressed="false" type="device" version="24.0.0">
  <diagram id="agent-skill-generator-workflow" name="Agent &amp; Command Generator for Claude Code CLI">
    <mxGraphModel dx="4200" dy="2400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="5600" pageHeight="3100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============================================================ -->
        <!-- POOL: Agent & Skill Generator for Claude Code CLI            -->
        <!-- ============================================================ -->
        <mxCell id="pool1" value="Agent &amp; Command Generator for Claude Code CLI" style="shape=mxgraph.bpmn.pool;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;horizontal=1;childLayout=stackLayout;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=0;marginBottom=0;swimlaneHead=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="5400" height="2700" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- LANE 1: User                                                 -->
        <!-- ============================================================ -->
        <mxCell id="lane_user" value="User" style="shape=mxgraph.bpmn.lane;startSize=40;fillColor=#e1d5e7;strokeColor=#9673a6;horizontal=1;swimlaneHead=0;fontStyle=1;fontSize=11;" vertex="1" parent="pool1">
          <mxGeometry y="30" width="5400" height="400" as="geometry" />
        </mxCell>

        <!-- START EVENT -->
        <mxCell id="evt_start" value="" style="shape=mxgraph.bpmn.event;perimeter=ellipsePerimeter;symbol=general;isLooping=0;isInterrupting=1;isConditional=0;outline=standard;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="lane_user">
          <mxGeometry x="60" y="160" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lbl_start" value="Generation&#xa;Request" style="text;html=0;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="lane_user">
          <mxGeometry x="40" y="205" width="80" height="30" as="geometry" />
        </mxCell>

        <!-- PHASE 1 LABEL -->
        <mxCell id="phase1_label" value="PHASE 1: Input &amp; Classification" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#9673a6;" vertex="1" parent="lane_user">
          <mxGeometry x="160" y="40" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Receive Generation Request -->
        <object label="Receive Generation&#xa;Request" agent="user" phase="1" phase_name="Input &amp; Classification" mandatory="true" status_from="new" status_to="received" rule="User specifies: agent or skill, role name, domain, expertise areas, target model, required MCP tools" id="task_receive_request">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=receive;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_user">
            <mxGeometry x="160" y="150" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Flow: Start -> Receive Request -->
        <mxCell id="flow_start_receive" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="evt_start" target="task_receive_request" parent="lane_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- LANE 2: Orchestrator                                         -->
        <!-- ============================================================ -->
        <mxCell id="lane_orchestrator" value="Orchestrator" style="shape=mxgraph.bpmn.lane;startSize=40;fillColor=#dae8fc;strokeColor=#6c8ebf;horizontal=1;swimlaneHead=0;fontStyle=1;fontSize=11;" vertex="1" parent="pool1">
          <mxGeometry y="430" width="5400" height="600" as="geometry" />
        </mxCell>

        <!-- Gateway: Agent or Skill? -->
        <mxCell id="gw_agent_or_skill" value="Agent or&#xa;Command?" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;gwType=exclusive;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="lane_orchestrator">
          <mxGeometry x="230" y="100" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- PHASE 2 LABEL -->
        <mxCell id="phase2_label" value="PHASE 2: Research &amp; Analysis" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#6c8ebf;" vertex="1" parent="lane_orchestrator">
          <mxGeometry x="500" y="40" width="260" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Analyze Existing Agents/Skills -->
        <object label="Analyze Existing&#xa;Agents/Skills" agent="agent_generator_orchestrator" phase="2" phase_name="Research &amp; Analysis" mandatory="true" status_from="received" status_to="analyzing" rule="Check ~/.claude/agents/ or ~/.claude/commands/ for similar existing files to avoid duplication and maintain consistency" id="task_analyze_existing">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=service;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestrator">
            <mxGeometry x="500" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Research Domain Expertise -->
        <object label="Research Domain&#xa;Expertise" agent="agent_generator_orchestrator" phase="2" phase_name="Research &amp; Analysis" mandatory="true" status_from="analyzing" status_to="researched" rule="Gather domain knowledge, identify key competencies, determine appropriate experience level" id="task_research_domain">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=script;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestrator">
            <mxGeometry x="740" y="80" width="180" height="60" as="geometry" />
