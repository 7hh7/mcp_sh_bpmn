        </mxCell>

        <!-- Flow: Compose Command Entry (Prompt Architect) -> Count Tokens (Token Validator) -->
        <mxCell id="flow_command_entry_to_tokens" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_compose_command_entry" target="task_count_tokens" parent="pool1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="2240" y="1800" />
              <mxPoint x="1900" y="1800" />
              <mxPoint x="1900" y="2200" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Flow: Assemble File (Token Validator) -> Validate Structure (Orchestrator) -->
        <mxCell id="flow_assemble_to_validate" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_assemble_file" target="task_validate_structure" parent="pool1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="3000" y="1960" />
              <mxPoint x="3420" y="1960" />
              <mxPoint x="3420" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Flow: Quality No (Rework) -> Design Persona (loop back to Phase 3) -->
        <!-- Note: Orchestrator determines whether to rework Agent or Command path based on context -->
        <mxCell id="flow_quality_rework" value="No (Rework)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#f8cecc;dashed=1;dashPattern=8 4;" edge="1" source="gw_quality_ok" target="task_design_persona" parent="pool1">
          <mxGeometry relative="1" as="geometry">
