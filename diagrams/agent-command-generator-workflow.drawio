          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=subprocess;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=1;instantiate=0;bpmnShapeType=task;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestrator">
