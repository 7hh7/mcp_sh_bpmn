        <mxCell id="flow_token_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#d5e8d4;" edge="1" source="gw_token_limit" target="task_assemble_file" parent="lane_token_validator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_token_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#f8cecc;" edge="1" source="gw_token_limit" target="task_trim_optimize" parent="lane_token_validator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Loopback: Trim -> Count Tokens -->
        <mxCell id="flow_trim_recount" value="Re-count" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#fff2cc;dashed=1;dashPattern=8 4;" edge="1" source="task_trim_optimize" target="task_count_tokens" parent="lane_token_validator">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="2090" y="280" />
              <mxPoint x="2090" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- CROSS-LANE FLOWS                                             -->
        <!-- ============================================================ -->

        <!-- Flow: Receive Request (User) -> Gateway Agent/Skill (Orchestrator) -->
        <mxCell id="flow_receive_to_gw" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_receive_request" target="gw_agent_or_skill" parent="pool1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Flow: Gateway Agent -> Analyze Existing (Agent path) -->
        <mxCell id="flow_gw_agent" value="Agent" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#e1d5e7;" edge="1" source="gw_agent_or_skill" target="task_analyze_existing" parent="pool1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Flow: Gateway Skill -> Analyze Existing (Skill path) -->
        <mxCell id="flow_gw_skill" value="Command" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#dae8fc;" edge="1" source="gw_agent_or_skill" target="task_analyze_existing" parent="pool1">
          <mxGeometry relative="1" as="geometry">
