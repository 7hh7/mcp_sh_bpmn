        <mxCell id="lbl_link_deep_research" value="&#x2192; deep-research&#xa;-workflow.drawio" style="text;html=0;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=9;fontColor=#666666;" vertex="1" parent="lane_orchestrator">
          <mxGeometry x="1040" y="190" width="120" height="30" as="geometry" />
        </mxCell>

        <!-- Annotation: Agent path -->
