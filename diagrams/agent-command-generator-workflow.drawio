              <mxPoint x="685" y="570" />
              <mxPoint x="930" y="570" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Flow: Research Domain (Orchestrator) -> Deep Research (Orchestrator) -->
        <mxCell id="flow_research_to_deep_research" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_research_domain" target="task_deep_research" parent="lane_orchestrator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Flow: Deep Research (Orchestrator) -> Routing Gateway (Orchestrator) -->
        <mxCell id="flow_deep_research_to_route_gw" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_deep_research" target="gw_agent_or_command_route" parent="lane_orchestrator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Gateway: Agent or Command Route (after Deep Research) -->
        <mxCell id="gw_agent_or_command_route" value="Agent or&#xa;Command?" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;gwType=exclusive;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="lane_orchestrator">
          <mxGeometry x="1300" y="85" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Flow: Route Gateway -> Design Persona (Agent path, cross-lane) -->
        <mxCell id="flow_route_to_persona" value="Agent" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#d5e8d4;" edge="1" source="gw_agent_or_command_route" target="task_design_persona" parent="pool1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1755" y="680" />
              <mxPoint x="1755" y="900" />
              <mxPoint x="980" y="900" />
              <mxPoint x="980" y="1140" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Flow: Route Gateway -> Design Command Role (Command path, cross-lane) -->
        <mxCell id="flow_route_to_command" value="Command" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#ffe6cc;" edge="1" source="gw_agent_or_command_route" target="task_design_command_role" parent="pool1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
