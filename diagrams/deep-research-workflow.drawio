        <!-- Annotation: Mandatory citation rule -->
        <mxCell id="note_citation_rule" value="MANDATORY: Every claim must&#xa;have a URL citation with&#xa;access date" style="shape=note2;boundedLbl=1;whiteSpace=wrap;rounded=0;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=2;fontSize=9;align=left;verticalAlign=middle;" vertex="1" parent="lane_synthesis">
