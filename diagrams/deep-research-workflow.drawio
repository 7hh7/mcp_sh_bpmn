        <!-- Task: Executive Summary -->
        <object label="Executive&#xa;Summary" agent="agent_research_browser" phase="5" phase_name="Report Synthesis" mandatory="true" rule="Write a concise summary with key findings, actionable insights, and recommended next steps" id="task_executive_summary">
