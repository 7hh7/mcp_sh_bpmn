        <mxCell id="flow_quality_no" value="No (Revise)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#fff2cc;dashed=1;dashPattern=8 4;" edge="1" source="gw_quality" target="task_compile_report" parent="lane_synthesis">
