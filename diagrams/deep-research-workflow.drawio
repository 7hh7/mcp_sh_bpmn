          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_synthesis">
