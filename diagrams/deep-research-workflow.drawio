          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_extraction">
