        <mxCell id="phase5_label" value="PHASE 5: Report Synthesis" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#7b1fa2;" vertex="1" parent="lane_synthesis">
