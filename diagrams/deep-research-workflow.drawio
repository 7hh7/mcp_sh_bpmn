        </object>

        <!-- Task: Add Citations -->
        <object label="Add Citations &amp;&#xa;References" agent="agent_research_browser" phase="5" phase_name="Report Synthesis" mandatory="true" rule="MANDATORY: Every claim must have URL citation. Format: [Source Title](URL) with access date." id="task_add_citations">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=manual;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_synthesis">
