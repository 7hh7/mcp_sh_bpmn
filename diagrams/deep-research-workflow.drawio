<mxfile host="app.diagrams.net" compressed="false" type="device" version="24.0.0">
  <diagram id="deep-research-workflow" name="Deep Internet Research Workflow">
    <mxGraphModel dx="4200" dy="2400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="5000" pageHeight="3200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============================================================ -->
        <!-- POOL: Deep Internet Research Workflow                        -->
        <!-- ============================================================ -->
        <mxCell id="pool1" value="Deep Internet Research Workflow" style="shape=mxgraph.bpmn.pool;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;horizontal=1;childLayout=stackLayout;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=0;marginBottom=0;swimlaneHead=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="4900" height="2700" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- LANE 1: Orchestration (Phases 1, 6)                         -->
        <!-- ============================================================ -->
        <mxCell id="lane_orchestration" value="Orchestration&#xa;(Phases 1, 6)" style="shape=mxgraph.bpmn.lane;startSize=40;fillColor=#e0f2f1;strokeColor=#00897b;horizontal=1;swimlaneHead=0;fontStyle=1;fontSize=11;" vertex="1" parent="pool1">
          <mxGeometry y="30" width="4900" height="500" as="geometry" />
        </mxCell>

        <!-- START EVENT -->
        <mxCell id="start1" value="" style="shape=mxgraph.bpmn.event;perimeter=ellipsePerimeter;symbol=general;isLooping=0;isInterrupting=1;isConditional=0;outline=standard;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="60" y="90" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="start1_label" value="Research&#xa;Start" style="text;html=0;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="45" y="135" width="70" height="30" as="geometry" />
        </mxCell>

        <!-- PHASE 1: Research Intake -->

        <mxCell id="phase1_label" value="PHASE 1: Research Intake" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#00897b;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="160" y="40" width="240" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Receive Research Request -->
        <object label="Receive Research&#xa;Request" agent="agent_research_browser" phase="1" phase_name="Research Intake" mandatory="true" rule="Parse user query, identify scope, extract key terms and constraints" id="task_receive_request">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=receive;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e0f2f1;strokeColor=#00897b;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestration">
            <mxGeometry x="160" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Classify Research Type -->
        <object label="Classify Research&#xa;Type" agent="agent_research_browser" phase="1" phase_name="Research Intake" mandatory="true" rule="Determine domain: security, code/tech, architecture, or general. Sets validation path." id="task_classify_type">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=business;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e0f2f1;strokeColor=#00897b;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestration">
            <mxGeometry x="400" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Define Research Strategy -->
        <object label="Define Research&#xa;Strategy" agent="agent_research_browser" phase="1" phase_name="Research Intake" mandatory="true" rule="Plan search queries, identify authoritative source categories, set depth and breadth targets" id="task_define_strategy">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e0f2f1;strokeColor=#00897b;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestration">
            <mxGeometry x="640" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Flows within Phase 1 -->
        <mxCell id="flow_start_receive" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="start1" target="task_receive_request" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_receive_classify" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_receive_request" target="task_classify_type" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_classify_strategy" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_classify_type" target="task_define_strategy" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PHASE 6: Action & Distribution -->

        <mxCell id="phase6_label" value="PHASE 6: Action &amp; Distribution" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#00897b;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="3200" y="250" width="260" height="30" as="geometry" />
        </mxCell>

        <!-- Gateway: MCP Servers Available? -->
        <mxCell id="gw_mcp_available" value="Wiki &amp; Projects&#xa;MCP Available?" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;gwType=exclusive;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="3240" y="295" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- PATH A: MCP Available — Wiki + Stories -->

        <!-- Task: Update Wiki -->
        <object label="Update Wiki" agent="agent_research_browser" phase="6" phase_name="Action &amp; Distribution" mandatory="true" rule="Store findings in SQSLN wiki using sh-wiki MCP. Create or update pages with full report." id="task_update_wiki">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=send;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e0f2f1;strokeColor=#00897b;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestration">
            <mxGeometry x="3400" y="290" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Create Stories -->
        <object label="Create Action&#xa;Stories" agent="agent_research_browser" phase="6" phase_name="Action &amp; Distribution" rule="Create stories in SQSLN projects for actionable findings using sh-projects MCP" id="task_create_stories">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=send;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e0f2f1;strokeColor=#00897b;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestration">
            <mxGeometry x="3640" y="290" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- PATH B: MCP Unavailable — Export to Markdown -->

        <!-- Task: Export Findings to Markdown -->
        <object label="Export Findings&#xa;to Markdown" agent="agent_research_browser" phase="6" phase_name="Action &amp; Distribution" mandatory="true" rule="Write all research findings, sources, confidence scores, and actionable items to a structured Markdown file in the working directory. Use filename pattern: research_TOPIC_DATE.md. Include sections: metadata, findings, sources, action_items, cross_references." id="task_export_markdown">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=send;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestration">
            <mxGeometry x="3500" y="130" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Merge Gateway: Distribution Complete -->
        <mxCell id="gw_distribution_merge" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;gwType=exclusive;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="3870" y="295" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Task: Archive Session -->
        <object label="Archive Research&#xa;Session" agent="agent_research_browser" phase="6" phase_name="Action &amp; Distribution" mandatory="true" rule="Close browser sessions, save screenshots, record metadata for audit trail" id="task_archive_session">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e0f2f1;strokeColor=#00897b;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_orchestration">
            <mxGeometry x="3980" y="290" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Gateway: More Topics? -->
        <mxCell id="gw_more_topics" value="More&#xa;Topics?" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;gwType=exclusive;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="4230" y="295" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- END EVENT -->
        <mxCell id="end1" value="" style="shape=mxgraph.bpmn.event;perimeter=ellipsePerimeter;symbol=terminate;isLooping=0;isInterrupting=0;isConditional=0;outline=end;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=3;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="4400" y="300" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="end1_label" value="Research&#xa;End" style="text;html=0;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="4385" y="345" width="70" height="30" as="geometry" />
        </mxCell>

        <!-- Annotation: Markdown fallback -->
        <mxCell id="note_markdown_fallback" value="Fallback when sh-wiki and&#xa;sh-projects MCP servers are&#xa;not registered. Writes to&#xa;research_TOPIC_DATE.md" style="shape=note2;boundedLbl=1;whiteSpace=wrap;rounded=0;size=14;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=2;fontSize=9;align=left;verticalAlign=middle;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="3480" y="70" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="note_markdown_fallback_link" value="" style="dashed=1;strokeColor=#999999;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="note_markdown_fallback" target="task_export_markdown" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Phase 6 Flows -->

        <!-- Gateway MCP Available -> Yes -> Update Wiki -->
        <mxCell id="flow_mcp_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#d5e8d4;" edge="1" source="gw_mcp_available" target="task_update_wiki" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Gateway MCP Available -> No -> Export Markdown -->
        <mxCell id="flow_mcp_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#ffe6cc;" edge="1" source="gw_mcp_available" target="task_export_markdown" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="3265" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Update Wiki -> Create Stories -->
        <mxCell id="flow_wiki_stories" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_update_wiki" target="task_create_stories" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Create Stories -> Merge Gateway -->
        <mxCell id="flow_stories_merge" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_create_stories" target="gw_distribution_merge" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Export Markdown -> Merge Gateway -->
        <mxCell id="flow_markdown_merge" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_export_markdown" target="gw_distribution_merge" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="3895" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Merge Gateway -> Archive Session -->
        <mxCell id="flow_merge_archive" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="gw_distribution_merge" target="task_archive_session" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Archive Session -> More Topics? -->
        <mxCell id="flow_archive_gw_topics" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_archive_session" target="gw_more_topics" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- More Topics GW -> No -> End -->
        <mxCell id="flow_topics_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#d5e8d4;" edge="1" source="gw_more_topics" target="end1" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- More Topics GW -> Yes -> loop back to Receive Request -->
        <mxCell id="flow_topics_yes" value="Yes (Next Topic)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#fff2cc;dashed=1;dashPattern=8 4;" edge="1" source="gw_more_topics" target="task_receive_request" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="4255" y="270" />
              <mxPoint x="250" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Annotation: Wiki MCP note -->
        <mxCell id="note_wiki_mcp" value="Uses sh-wiki MCP to store&#xa;research in SQSLN wiki" style="shape=note2;boundedLbl=1;whiteSpace=wrap;rounded=0;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=2;fontSize=9;align=left;verticalAlign=middle;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="3400" y="380" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="note_wiki_mcp_link" value="" style="dashed=1;strokeColor=#999999;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="note_wiki_mcp" target="task_update_wiki" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Annotation: Projects MCP note -->
        <mxCell id="note_projects_mcp" value="Uses sh-projects MCP for&#xa;actionable follow-up stories" style="shape=note2;boundedLbl=1;whiteSpace=wrap;rounded=0;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=2;fontSize=9;align=left;verticalAlign=middle;" vertex="1" parent="lane_orchestration">
          <mxGeometry x="3640" y="380" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="note_projects_mcp_link" value="" style="dashed=1;strokeColor=#999999;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="note_projects_mcp" target="task_create_stories" parent="lane_orchestration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- LANE 2: Discovery (Phase 2)                                  -->
        <!-- ============================================================ -->
        <mxCell id="lane_discovery" value="Discovery&#xa;(Phase 2)" style="shape=mxgraph.bpmn.lane;startSize=40;fillColor=#e8eaf6;strokeColor=#3949ab;horizontal=1;swimlaneHead=0;fontStyle=1;fontSize=11;" vertex="1" parent="pool1">
          <mxGeometry y="530" width="4900" height="300" as="geometry" />
        </mxCell>

        <mxCell id="phase2_label" value="PHASE 2: Source Discovery" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#3949ab;" vertex="1" parent="lane_discovery">
          <mxGeometry x="900" y="30" width="240" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Broad Search -->
        <object label="Broad Search" agent="agent_research_browser" phase="2" phase_name="Source Discovery" mandatory="true" rule="Execute planned search queries across multiple engines. Use browser for JS-rendered results." id="task_broad_search">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e8eaf6;strokeColor=#3949ab;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_discovery">
            <mxGeometry x="900" y="70" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Identify Authoritative Sources -->
        <object label="Identify Authoritative&#xa;Sources" agent="agent_research_browser" phase="2" phase_name="Source Discovery" mandatory="true" rule="Rank sources by authority: official docs, peer-reviewed, reputable news, community. Discard low-quality." id="task_identify_sources">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e8eaf6;strokeColor=#3949ab;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_discovery">
            <mxGeometry x="1140" y="70" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Filter & Prioritize -->
        <object label="Filter &amp;&#xa;Prioritize" agent="agent_research_browser" phase="2" phase_name="Source Discovery" mandatory="true" rule="Remove duplicates, assess relevance to query, order by information density and recency" id="task_filter_prioritize">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e8eaf6;strokeColor=#3949ab;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_discovery">
            <mxGeometry x="1380" y="70" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Gateway: Enough Sources? -->
        <mxCell id="gw_enough_sources" value="Enough&#xa;Sources?" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;gwType=exclusive;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;" vertex="1" parent="lane_discovery">
          <mxGeometry x="1620" y="75" width="50" height="50" as="geometry" />
        </mxCell>

        <!-- Discovery Flows -->
        <mxCell id="flow_search_identify" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_broad_search" target="task_identify_sources" parent="lane_discovery">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_identify_filter" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_identify_sources" target="task_filter_prioritize" parent="lane_discovery">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flow_filter_gw_sources" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" source="task_filter_prioritize" target="gw_enough_sources" parent="lane_discovery">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Enough Sources GW -> No -> loop back to Broad Search -->
        <mxCell id="flow_sources_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;fontStyle=1;fontSize=10;labelBackgroundColor=#fff2cc;dashed=1;dashPattern=8 4;" edge="1" source="gw_enough_sources" target="task_broad_search" parent="lane_discovery">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1645" y="200" />
              <mxPoint x="990" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- LANE 3: Deep Extraction (Phase 3)                            -->
        <!-- ============================================================ -->
        <mxCell id="lane_extraction" value="Deep Extraction&#xa;(Phase 3)" style="shape=mxgraph.bpmn.lane;startSize=40;fillColor=#e3f2fd;strokeColor=#1565c0;horizontal=1;swimlaneHead=0;fontStyle=1;fontSize=11;" vertex="1" parent="pool1">
          <mxGeometry y="830" width="4900" height="350" as="geometry" />
        </mxCell>

        <mxCell id="phase3_label" value="PHASE 3: Deep Extraction" style="text;html=0;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=5;fontColor=#1565c0;" vertex="1" parent="lane_extraction">
          <mxGeometry x="1800" y="30" width="240" height="30" as="geometry" />
        </mxCell>

        <!-- Task: Navigate to Source -->
        <object label="Navigate to&#xa;Source" agent="agent_research_browser" phase="3" phase_name="Deep Extraction" mandatory="true" rule="Use sh-browser page_navigate to load each prioritized source URL" id="task_navigate">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_extraction">
            <mxGeometry x="1800" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Handle Obstacles -->
        <object label="Handle Obstacles" agent="agent_research_browser" phase="3" phase_name="Deep Extraction" rule="Dismiss cookie walls, accept ToS, handle popups, scroll lazy-loaded content via page_click and cdp_js_execute" id="task_handle_obstacles">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_extraction">
            <mxGeometry x="2040" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Extract Content -->
        <object label="Extract Content" agent="agent_research_browser" phase="3" phase_name="Deep Extraction" mandatory="true" rule="Use page_get_text and page_get_html to extract key data. Parse tables, code blocks, and structured content." id="task_extract_content">
          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_extraction">
            <mxGeometry x="2280" y="80" width="180" height="60" as="geometry" />
          </mxCell>
        </object>

        <!-- Task: Follow Internal Links -->
