          <mxCell style="shape=mxgraph.bpmn.task;taskMarker=abstract;isLooping=0;isAdHoc=0;isCompensation=0;isCollapsed=0;instantiate=0;bpmnShapeType=task;fillColor=#fce4ec;strokeColor=#c62828;fontStyle=1;fontSize=11;whiteSpace=wrap;" vertex="1" parent="lane_validation">
